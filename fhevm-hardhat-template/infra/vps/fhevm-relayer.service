[Unit]
Description=FHEVM Vote - Relayer mock (HTTP proxy to Hardhat relayer JSON-RPC)
After=fhevm-hardhat.service
BindsTo=fhevm-hardhat.service

[Service]
Type=simple
User=fhevm
WorkingDirectory=/opt/fhevm-vote/fhevm-hardhat-template
ExecStart=/usr/bin/python3 relayer_proxy.py
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
